generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Atm {
  id        String   @id @default(cuid())
  tid       Int      @unique
  location  String
  branch    String
  ssb       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices       Device[]
  tickets       Ticket[]
  visits        Visit[]
  logs          AtmLog[]
  deviceHistory DeviceHistory[]

  @@map("atms")
}

model AtmLog {
  id        String   @id @default(cuid())
  note      String? // catatan riwayat (mis. kunjungan, temuan, perbaikan umum)
  createdAt DateTime @default(now())

  atm   Atm    @relation(fields: [atmId], references: [id], onDelete: Cascade)
  atmId String

  photos AtmLogPhoto[]

  @@map("atm_logs")
}

model AtmLogPhoto {
  id        String   @id @default(cuid())
  url       String // secure_url dari Cloudinary
  publicId  String // public_id Cloudinary, dipakai kalau nanti mau hapus foto
  createdAt DateTime @default(now())

  log   AtmLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  logId String

  @@map("atm_log_photos")
}

enum DeviceType {
  NVR
  MONITOR
  CCTV
  UPS
}

enum DeviceCondition {
  GOOD
  DAMAGED
  NEEDS_REPLACEMENT
}

model Device {
  id           String          @id @default(cuid())
  type         DeviceType
  brand        String
  serialNumber String          @unique
  condition    DeviceCondition @default(GOOD)
  note         String? // catatan kondisi/problem
  photoUrl     String? // url dari Cloudinary
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt // ini yang jadi "Last Update"

  atm   Atm    @relation(fields: [atmId], references: [id], onDelete: Cascade)
  atmId String

  tickets Ticket[]
  logs    DeviceLog[]

  @@map("devices")
}

model DeviceLog {
  id        String   @id @default(cuid())
  note      String? // catatan riwayat perangkat (mis. pengecekan, perbaikan, kondisi terbaru)
  createdAt DateTime @default(now())

  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId String

  photos DeviceLogPhoto[]

  @@map("device_logs")
}

model DeviceLogPhoto {
  id        String   @id @default(cuid())
  url       String // secure_url dari Cloudinary
  publicId  String // public_id Cloudinary, dipakai kalau nanti mau hapus foto
  createdAt DateTime @default(now())

  log   DeviceLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  logId String

  @@map("device_log_photos")
}

enum DeviceHistoryAction {
  ADDED
  REPLACED
  REMOVED
}

// Riwayat pasang/ganti/lepas perangkat di sebuah ATM. Baris ini tetap disimpan
// walau Device aslinya sudah dihapus/diganti, jadi datanya "flat" (bukan relasi
// ke Device) supaya riwayat tidak ikut hilang.
model DeviceHistory {
  id           String              @id @default(cuid())
  action       DeviceHistoryAction
  deviceType   DeviceType
  brand        String
  serialNumber String
  note         String?
  createdAt    DateTime            @default(now())

  atm   Atm    @relation(fields: [atmId], references: [id], onDelete: Cascade)
  atmId String

  @@map("device_history")
}

enum KasetType {
  ALL_IN
  CURRENCY
}

model Kaset {
  id           String    @id @default(cuid())
  serialNumber String    @unique
  type         KasetType @default(ALL_IN)
  createdAt    DateTime  @default(now())

  logs KasetLog[]

  @@map("kaset")
}

model KasetLog {
  id        String          @id @default(cuid())
  condition DeviceCondition 
  problem   String? 
  createdAt DateTime        @default(now()) // ini "waktu dicatat" sekaligus "last update" kaset

  kaset   Kaset  @relation(fields: [kasetId], references: [id], onDelete: Cascade)
  kasetId String

  photos KasetLogPhoto[]

  @@map("kaset_logs")
}

model KasetLogPhoto {
  id        String   @id @default(cuid())
  url       String // secure_url dari Cloudinary
  publicId  String // public_id Cloudinary, dipakai kalau nanti mau hapus foto
  createdAt DateTime @default(now())

  log   KasetLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  logId String

  @@map("kaset_log_photos")
}


enum TicketStatus {
  OPEN
  CLOSED
}

model Ticket {
  id           String       @id @default(cuid())
  problem      String
  ticketNumber String? // diisi manual saat close, kosong selama OPEN
  action       String? // diisi manual saat close
  status       TicketStatus @default(OPEN)
  openedAt     DateTime     @default(now())
  closedAt     DateTime?

  atm   Atm    @relation(fields: [atmId], references: [id], onDelete: Cascade)
  atmId String

  // device (NVR/Monitor/CCTV/UPS) yang jadi rujukan/diperbaiki di tiket ini,
  // dipilih dari device-device milik ATM yang sama
  device   Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  deviceId String?

  attachments TicketAttachment[]
  visits      Visit[]

  @@map("tickets")
}

model TicketAttachment {
  id           String   @id @default(cuid())
  url          String // secure_url dari Cloudinary
  publicId     String // public_id Cloudinary, dipakai kalau nanti mau hapus foto
  resourceType String // "image" atau "raw" (pdf)
  filename     String? // nama file asli, dipakai buat lampiran PDF
  createdAt    DateTime @default(now())

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId String

  @@map("ticket_attachments")
}

enum FinanceType {
  DEBIT
  CREDIT
}

enum FinanceCategory {
  KETERANGAN
  TRANSPORTASI
  SPJ
  HOTEL
  PENGIRIMAN
  OPERASIONAL
}

// Catatan uang operasional (kas masuk/keluar), difilter per bulan di UI.
model FinanceEntry {
  id          String          @id @default(cuid())
  date        DateTime // tanggal transaksi (diisi manual, bukan createdAt)
  description String
  type        FinanceType
  amount      Int // nominal dalam Rupiah, selalu bernilai positif
  category    FinanceCategory
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Diisi otomatis kalau entri ini datang dari pemesanan Travel atau Hotel,
  // atau dari satu item barang di sebuah Penjualan.
  travel   Travel?
  hotel    Hotel?
  saleItem SaleItem?

  @@index([date])
  @@map("finance_entries")
}

enum TravelVehicle {
  AVANZA
  XENIA
  SIGRA
  XPANDER
}

// Pemesanan travel. Setiap pemesanan otomatis membuat satu FinanceEntry (debit,
// kategori TRANSPORTASI) yang tetap disinkronkan saat travel diedit/dihapus.
model Travel {
  id             String        @id @default(cuid())
  invoiceNo      String        @unique // huruf kapital + angka acak 8 karakter, dibuat otomatis
  customerName   String
  orderDate      DateTime
  departureDate  DateTime
  origin         String
  destination    String
  vehicle        TravelVehicle
  price          Int // harga travel dalam Rupiah
  passengerCount Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  financeEntry   FinanceEntry? @relation(fields: [financeEntryId], references: [id], onDelete: SetNull)
  financeEntryId String?       @unique

  @@map("travels")
}

enum HotelRoomType {
  SUPER_SINGLE
  DELUXE_DOUBLE
  DELUXE_TWIN
  EXECUTIVE
}

enum HotelPaymentMethod {
  ALFAMART
  BRIVA
  INDOMARET
  OVO
  SHOPEEPAY
  QRIS
}

// Pemesanan hotel. Setiap pemesanan otomatis membuat satu FinanceEntry (debit,
// kategori HOTEL) yang tetap disinkronkan saat pemesanan diedit/dihapus.
model Hotel {
  id             String             @id @default(cuid())
  bookingNo      String             @unique // angka acak 19 digit, dibuat otomatis
  poBooking      String             @unique // angka acak 9 digit, dibuat otomatis
  customerName   String
  email          String
  phone          String
  bookingDate    DateTime
  checkinDate    DateTime
  hotelName      String
  hotelAddress   String
  roomType       HotelRoomType
  duration       Int // jumlah malam
  guestCount     Int
  price          Int // harga hotel dalam Rupiah
  paymentMethod  HotelPaymentMethod
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  financeEntry   FinanceEntry? @relation(fields: [financeEntryId], references: [id], onDelete: SetNull)
  financeEntryId String?       @unique

  @@map("hotels")
}

enum VisitType {
  PM
  CM
}

model Visit {
  id           String    @id @default(cuid())
  visitType    VisitType
  visitDate    DateTime  @default(now())
  ticketNumber String? // diisi manual, khusus untuk visit tipe PM
  keterangan   String? // catatan hasil kunjungan
  photoUrl     String? // url foto dokumentasi kunjungan (Cloudinary/host lain)
  createdAt    DateTime  @default(now())

  atm   Atm    @relation(fields: [atmId], references: [id], onDelete: Cascade)
  atmId String

  // khusus visit tipe CM: relasi ke tiket yang statusnya sudah CLOSED,
  // nomor tiketnya diambil dari Ticket.ticketNumber (bukan dari field di atas)
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  ticketId String?

  @@map("visits")
}

// Data master barang yang dijual. Stock berkurang otomatis setiap ada Penjualan.
model Product {
  id        String   @id @default(cuid())
  code      String   @unique // Kode Product, diisi manual
  name      String
  category  String
  stock     Int      @default(0)
  price     Int // harga jual dalam Rupiah
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems SaleItem[]

  @@map("products")
}

// Transaksi penjualan. Bisa berisi banyak barang (SaleItem) dalam satu transaksi.
model Sale {
  id           String   @id @default(cuid())
  invoiceNo    String   @unique // dibuat otomatis
  saleDate     DateTime // tanggal & jam penjualan (diisi manual)
  customerName String
  totalAmount  Int // total harga seluruh item, dihitung otomatis
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items SaleItem[]

  @@map("sales")
}

// Satu baris barang di dalam sebuah Penjualan. Setiap baris otomatis membuat
// satu FinanceEntry sendiri-sendiri (debit, kategori OPERASIONAL) supaya
// kalau 1 transaksi penjualan ada 5 barang, di Keuangan juga muncul 5 baris.
model SaleItem {
  id          String   @id @default(cuid())
  productName String // snapshot nama produk saat transaksi (tetap ada walau produk dihapus)
  productCode String // snapshot kode produk saat transaksi
  quantity    Int
  unitPrice   Int // snapshot harga satuan saat transaksi
  subtotal    Int // quantity * unitPrice
  createdAt   DateTime @default(now())

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId String

  // Dipertahankan sebagai referensi ke master produk (kalau masih ada), tapi
  // tidak wajib supaya riwayat penjualan tidak ikut hilang kalau produknya dihapus.
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?

  financeEntry   FinanceEntry? @relation(fields: [financeEntryId], references: [id], onDelete: SetNull)
  financeEntryId String?       @unique

  @@map("sale_items")
}
